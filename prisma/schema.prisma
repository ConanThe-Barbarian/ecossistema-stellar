generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
}

model anexos {
  id           String      @id(map: "PK__anexos__3213E83FD354DE4A") @default(dbgenerated("newid()"), map: "DF__anexos__id__47A6A41B") @db.UniqueIdentifier
  chamado_id   String?     @db.UniqueIdentifier
  interacao_id String?     @db.UniqueIdentifier
  nome_arquivo String      @db.NVarChar(255)
  url_arquivo  String      @db.NVarChar(Max)
  tipo_arquivo String?     @db.VarChar(50)
  created_at   DateTime    @default(now(), map: "DF__anexos__created___489AC854")
  chamados     chamados?   @relation(fields: [chamado_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Anexos_Chamados")
  interacoes   interacoes? @relation(fields: [interacao_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Anexos_Interacoes")
}

model chamados {
  id                                                 String       @id(map: "PK__chamados__3213E83FE2BD7942") @default(dbgenerated("newid()"), map: "DF__chamados__id__3493CFA7") @db.UniqueIdentifier
