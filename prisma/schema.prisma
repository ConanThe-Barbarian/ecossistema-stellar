  requerente_id                                      String       @db.UniqueIdentifier
  empresa_responsavel_id                             String       @db.UniqueIdentifier
  tecnico_atribuido_id                               String?      @db.UniqueIdentifier
  titulo                                             String       @db.NVarChar(200)
  descricao                                          String       @db.NVarChar(Max)
  categoria                                          String       @db.VarChar(50)
  prioridade                                         String       @db.VarChar(20)
  status                                             String       @default("NOVO", map: "DF_chamados_status") @db.VarChar(30)
  data_limite_resposta                               DateTime?
  data_limite_solucao                                DateTime?
  tempo_gasto_minutos                                Int          @default(0, map: "DF__chamados__tempo___3864608B")
  created_at                                         DateTime     @default(now(), map: "DF__chamados__create__395884C4")
  updated_at                                         DateTime     @default(now(), map: "DF__chamados__update__3A4CA8FD")
  anexos                                             anexos[]
  empresas_chamados_empresa_origem_idToempresas      empresas     @relation("chamados_empresa_origem_idToempresas", fields: [empresa_origem_id], references: [id], onUpdate: NoAction, map: "FK_Chamados_EmpresaOrigem")
  empresas_chamados_empresa_responsavel_idToempresas empresas     @relation("chamados_empresa_responsavel_idToempresas", fields: [empresa_responsavel_id], references: [id], onUpdate: NoAction, map: "FK_Chamados_EmpresaResponsavel")
  usuarios_chamados_requerente_idTousuarios          usuarios     @relation("chamados_requerente_idTousuarios", fields: [requerente_id], references: [id], onUpdate: NoAction, map: "FK_Chamados_Requerente")
  usuarios_chamados_tecnico_atribuido_idTousuarios   usuarios?    @relation("chamados_tecnico_atribuido_idTousuarios", fields: [tecnico_atribuido_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Chamados_Tecnico")
  interacoes                                         interacoes[]
}

model config_slas {
  id                   String   @id(map: "PK__config_s__3213E83F19702931") @default(dbgenerated("newid()"), map: "DF__config_slas__id__2EDAF651") @db.UniqueIdentifier
